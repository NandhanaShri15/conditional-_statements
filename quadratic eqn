import math
a=float(input("Enter a:"))
b=float(input("Enter b:"))
c=float(input("Enter c:"))
D=(b*b)-(4*a*c)
if D==0:
    print("Roots are:")
    print(-b/(2*a))
    print(-b/(2*a))
    print("The roots are real and equal")
elif D>0:
    print("Roots are:")
    print((-b+math.sqrt(D))/(2*a))
    print((-b-math.sqrt(D))/(2*a))
    print("The roots are real and distinct")
else:
    print("Roots are imaginary")
